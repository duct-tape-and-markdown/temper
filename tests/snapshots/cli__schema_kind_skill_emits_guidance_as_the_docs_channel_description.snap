---
source: tests/cli.rs
expression: stdout
---
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "not": {
        "required": [
          "globs"
        ]
      }
    },
    {
      "not": {
        "required": [
          "alwaysApply"
        ]
      }
    }
  ],
  "properties": {
    "description": {
      "maxLength": 1024,
      "minLength": 1
    },
    "name": {
      "description": "Keep the name a short, slug-like identifier — lower-case and hyphenated.",
      "maxLength": 64,
      "minLength": 1,
      "not": {
        "enum": [
          "anthropic",
          "claude"
        ]
      },
      "pattern": "^[a-z0-9\\-]*$"
    }
  },
  "required": [
    "name",
    "description"
  ],
  "type": "object"
}
