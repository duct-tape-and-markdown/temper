---
source: tests/install.rs
expression: settings
---
{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "temper guard .",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "temper check . --reporter session-start",
            "type": "command"
          }
        ]
      }
    ]
  }
}
