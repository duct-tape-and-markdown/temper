# Rust
/target
**/*.rs.bk

# Node (flume harness control plane only)
/node_modules

# Flume harness-managed state (not authored, not committed)
/.flume/worktrees/
/.flume/sessions/
/.flume/awake/
/.flume/metrics.jsonl
/.flume/prior-attempts/

# The dogfood authoring workspace (`.temper/`) IS committed — member modules,
# harness.ts, lock.toml — its node dependencies are not. Same split for the
# example harnesses' workspaces.
/.temper/node_modules/
/examples/*/.temper/node_modules/

# The per-machine tap event log (`temper tap` appends; machine-written, never
# committed, never an emit input or target).
/.temper/tap.jsonl
/examples/*/.temper/tap.jsonl

# SDK build output
sdk/dist/
sdk/node_modules/

# Secrets — never committed (plan ticks stage with `git add -A`)
.env
.env.*
