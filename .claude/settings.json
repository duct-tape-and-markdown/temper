{
  "autoMemoryEnabled": false,
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "cargo fmt --quiet >/dev/null 2>&1 || true",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)"
    ]
  }
}
