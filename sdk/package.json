{
  "name": "@dtmd/temper",
  "version": "0.0.7",
  "description": "The temper authoring face — the six-noun model as typed modules: harness(), kind<T>(), clause values, needs, and file()/text/blocks(). Emit compiles to the declaration rows the engine reads, a byte-faithful projection, and the lock.",
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duct-tape-and-markdown/temper.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/duct-tape-and-markdown/temper#readme",
  "bugs": "https://github.com/duct-tape-and-markdown/temper/issues",
  "keywords": [
    "claude-code",
    "claude",
    "harness",
    "linter",
    "typed-config"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./claude-code": {
      "types": "./dist/src/claude-code.d.ts",
      "default": "./dist/src/claude-code.js"
    }
  },
  "files": [
    "dist/src",
    "bin",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "rm -rf dist && tsc -p tsconfig.json && node --test \"dist/test/**/*.test.js\"",
    "prepublishOnly": "npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "bin": {
    "temper": "bin/temper.js"
  },
  "optionalDependencies": {
    "@dtmd/temper-linux-x64": "0.0.7",
    "@dtmd/temper-win32-x64": "0.0.7"
  }
}
